# Render with:
#   d2 --layout=elk --elk-nodeNodeBetweenLayers=20 \
#      --elk-padding='[top=4,left=4,bottom=4,right=4]' \
#      --theme=0 --dark-theme=200 --pad=8 \
#      architecture.d2 architecture.svg
# Then post-process with postprocess.py to (a) drop the page-background
# white rect (the matching one inside <mask> must stay or arrows
# disappear), (b) bold only the first text line of each shape (the
# package name), and (c) inject a dark-mode @media block flipping the
# explicit layer fills + strokes to readable shades for
# prefers-color-scheme: dark.

vars: {
  d2-config: {
    pad: 8
  }
}

# Transparent root so the SVG inherits the host page's
# light/dark background; theme-aware fills handle the rest.
style.fill: transparent

direction: down

# Three colour groups read at a glance:
#   * orchestration (blue) — the surface the operator drives
#   * agent runtime stack (teal) — everything that runs and bounds
#                                  an agent task
#   * system foundation (slate) — the OS pieces we sit on
classes: {
  orchestration: {
    style: {
      fill: "#dbeafe"
      stroke: "#1d4ed8"
      stroke-width: 1
      border-radius: 12
    }
  }
  runtime: {
    style: {
      fill: "#ccfbf1"
      stroke: "#0d9488"
      stroke-width: 1
      border-radius: 12
    }
  }
  system: {
    style: {
      fill: "#f1f5f9"
      stroke: "#475569"
      stroke-width: 1
      border-radius: 12
    }
  }
}

terok: "terok\nProject orchestration · multi-agent presets · TUI · sickbay" {
  class: orchestration
}

executor: "terok-executor\nPer-task agent runner · image factory · auth flows" {
  class: runtime
}

sandbox: "terok-sandbox\nHardened Podman runtime · credential vault · git gate" {
  class: runtime
}

shield: "terok-shield\nnftables egress firewall · default-deny · audit" {
  class: runtime
}

clearance: "terok-clearance\nLive Allow / Deny · D-Bus + varlink hub" {
  class: runtime
}

system: "System foundation\nrootless Podman · nftables · systemd · D-Bus" {
  class: system
}

terok -> executor
executor -> sandbox
sandbox -> shield
sandbox -> clearance
shield -> system
clearance -> system
